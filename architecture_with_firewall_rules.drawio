          <mxGeometry x="510" y="175" width="490" height="180" as="geometry" />
        </mxCell>
        <mxCell id="rule-net1" value="onprem-to-cloud (Priority 100)&#xa;allow-ping: on-premises → cclab (ICMP)&#xa;allow-administrative-access: on-premises → cclab (TCP/UDP :22, :3389)" style="rounded=1;fillColor=#e8f5e9;strokeColor=#82b366;fontSize=9;align=left;" vertex="1" parent="rcg-net">
