        </mxCell>
        <mxCell id="rule-app2" value="allow-inbound-webapp-demo&#xa;Sources: on-premises + cclab&#xa;Target: appsvc-webapp-demo.azurewebsites.net (HTTPS:443)  →  Allow" style="rounded=1;fillColor=#fffde7;strokeColor=#d6b656;fontSize=9;align=left;" vertex="1" parent="rcg-app">
