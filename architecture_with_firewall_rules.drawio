        <!-- Application Rule Collection Group -->
        <mxCell id="rcg-app" value="Application Rule Collection Group (Priority 100)" style="swimlane;startSize=25;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=10;fontStyle=1;" vertex="1" parent="fw-policy-group">
