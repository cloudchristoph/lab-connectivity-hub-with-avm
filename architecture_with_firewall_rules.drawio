        </mxCell>
        <mxCell id="rule-app1" value="allow-outbound-web-traffic&#xa;Sources: oad-azurefirewall + webapp-demo&#xa;Target: * (HTTP:80, HTTPS:443)  →  Allow" style="rounded=1;fillColor=#fffde7;strokeColor=#d6b656;fontSize=9;align=left;" vertex="1" parent="rcg-app">
