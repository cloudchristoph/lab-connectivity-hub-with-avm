        </mxCell>
        <mxCell id="rule-net1" value="onprem-to-cloud (Priority 100)&#xa;allow-ping: on-premises → cclab (ICMP)&#xa;allow-administrative-access: on-premises → cclab (TCP/UDP :22, :3389)"
